<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:MauiCSS.ViewModels"
             x:Class="MauiCSS.Views.MainView"
             Title="System losowania uczniów">
    <ContentPage.BindingContext>
        <viewmodels:MainViewModel />
    </ContentPage.BindingContext>
    <AbsoluteLayout>
        <ScrollView AbsoluteLayout.LayoutBounds="0,0,1,1"
                    AbsoluteLayout.LayoutFlags="All">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnDefinitions="*,2*"
                  Padding="10"
                  RowSpacing="10"
                  ColumnSpacing="10">

                <!-- status bar -->
                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                    <Label Text="System losowania"
                           Style="{StaticResource Headline}"
                           StyleClass="title-label" />
                    <Label Text="{Binding StatusMessage}"
                           HorizontalOptions="Center"
                           StyleClass="status-label" />
                </VerticalStackLayout>

                <!-- class management -->
                <Frame Grid.Row="1" Grid.Column="0"
                       BackgroundColor="{StaticResource Secondary}"
                       BorderColor="{StaticResource Gray200}"
                       CornerRadius="10"
                       Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Zarządzanie klasami"
                               StyleClass="section-header"/>
                        <HorizontalStackLayout Spacing="5">
                            <Entry Placeholder="Nazwa nowej klasy"
                                   Text="{Binding Class.NewClassName}"
                                   WidthRequest="150" />
                            <Button Text="+"
                                    Command="{Binding Class.CreateClassCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    WidthRequest="40"
                                    StyleClass="primary-button"/>
                        </HorizontalStackLayout>
                        <Picker Title="Wybierz klasę"
                                ItemsSource="{Binding Class.ClassNames}"
                                SelectedItem="{Binding Class.SelectedClassName}" />
                        <HorizontalStackLayout Spacing="6" Margin="0,6,0,0">
                            <Entry Placeholder="Nowa nazwa klasy"
                                   Text="{Binding Class.NewSelectedClassName}"
                                   WidthRequest="180" />
                            <Button Text="Zmień nazwę"
                                    Command="{Binding Class.RenameClassCommand}"
                                    IsVisible="{Binding Class.IsClassSelected}"
                                    BackgroundColor="{StaticResource Primary}" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="8">
                            <Button Text="Importuj"
                                    Command="{Binding StudentList.ImportClassCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    IsVisible="{Binding Class.IsClassSelected}"
                                    StyleClass="primary-button" />
                            <Button Text="Eksportuj"
                                    Command="{Binding StudentList.ExportClassCommand}"
                                    BackgroundColor="{StaticResource PrimaryDark}"
                                    IsVisible="{Binding Class.IsClassSelected}"
                                    StyleClass="secondary-button" />
                        </HorizontalStackLayout>
                        <Label Text="Eksport zapisuje do wybranego miejsca"
                               Style="{StaticResource HelperText}"
                               StyleClass="status-label" />
                        <Button Text="Usuń klasę"
                                Command="{Binding Class.DeleteClassCommand}"
                                BackgroundColor="{StaticResource PrimaryDark}"
                                IsVisible="{Binding Class.IsClassSelected}"
                                StyleClass="danger-button"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- lucky number -->
                <Frame Grid.Row="1" Grid.Column="1"
                       BackgroundColor="{StaticResource Secondary}"
                       BorderColor="{StaticResource Primary}"
                       CornerRadius="10"
                       Padding="15">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Szczęśliwy numerek"
                                   StyleClass="section-header"/>
                            <Label Text="{Binding LuckyNumber.LuckyNumber}"
                                   HorizontalOptions="Center"
                                   StyleClass="lucky-number-label"/>
                            <Label Text="Tutaj możesz wpisać szczęśliwy numerek (ręcznie) lub użyć przycisku."
                                   Style="{StaticResource HelperText}"
                                   StyleClass="status-label"/>
                        </VerticalStackLayout>
                        <Entry Grid.Column="1"
                               Text="{Binding LuckyNumber.LuckyNumberString, Mode=TwoWay}"
                               Keyboard="Numeric"
                               WidthRequest="200"
                               VerticalOptions="Center"
                               Placeholder="Wpisz numer"
                               TextColor="{StaticResource BeeDark}"
                               BackgroundColor="{StaticResource Secondary}" />
                        <Button Grid.Column="2"
                                Text="Losuj numerek"
                                Command="{Binding LuckyNumber.GenerateLuckyNumberCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                VerticalOptions="Center"
                                StyleClass="primary-button"/>
                    </Grid>
                </Frame>

                <!-- student list controls -->
                <Frame Grid.Row="2" Grid.Column="0"
                       BackgroundColor="{StaticResource Secondary}"
                       BorderColor="{StaticResource Gray200}"
                       CornerRadius="10"
                       Padding="15"
                       IsVisible="{Binding Class.IsClassSelected}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Dodaj ucznia"
                               StyleClass="section-header"/>
                        <Entry Placeholder="Imię i nazwisko"
                               Text="{Binding StudentList.NewStudentName}" />
                        <Button Text="Dodaj ucznia"
                                Command="{Binding StudentList.AddStudentCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                StyleClass="success-button"/>
                        <HorizontalStackLayout Spacing="10">
                            <Button Text="{Binding StudentList.IsEditing, Converter={StaticResource BoolToEditTextConverter}}"
                                    Command="{Binding StudentList.ToggleEditModeCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    StyleClass="primary-button"/>
                            <Button Text="Resetuj"
                                    Command="{Binding StudentList.ResetQuestionedCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    StyleClass="primary-button"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- draw panel -->
                <Frame Grid.Row="2" Grid.Column="1"
                       BackgroundColor="{StaticResource Secondary}"
                       BorderColor="{StaticResource Gray200}"
                       CornerRadius="15"
                       Padding="20"
                       IsVisible="{Binding Class.IsClassSelected}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <Label Grid.Column="0" Text=""
                                   HorizontalOptions="Center"
                                   StyleClass="section-header"/>
                            <Frame Grid.Column="1"
                                   BackgroundColor="{StaticResource PrimaryDark}"
                                   CornerRadius="10" Padding="6,10"
                                   WidthRequest="14" HeightRequest="60"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Frame BackgroundColor="{StaticResource PrimaryDark}"
                               BorderColor="{StaticResource Gray200}"
                               CornerRadius="14" Padding="12">
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" HorizontalOptions="Center">
                                <Frame Grid.Column="0"
                                       BackgroundColor="{StaticResource BeeLight}"
                                       BorderColor="{StaticResource Gray200}"
                                       CornerRadius="10" Padding="8"
                                       WidthRequest="70" HeightRequest="90">
                                    <Label Text="{Binding Draw.SlotDigit1}"
                                           StyleClass="slot-digit"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Frame>
                                <Frame Grid.Column="1"
                                       BackgroundColor="{StaticResource BeeLight}"
                                       BorderColor="{StaticResource Gray200}"
                                       CornerRadius="10" Padding="8"
                                       WidthRequest="70" HeightRequest="90">
                                    <Label Text="{Binding Draw.SlotDigit2}"
                                           StyleClass="slot-digit"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Frame>
                                <Frame Grid.Column="2"
                                       BackgroundColor="{StaticResource BeeLight}"
                                       BorderColor="{StaticResource Gray200}"
                                       CornerRadius="10" Padding="8"
                                       WidthRequest="70" HeightRequest="90">
                                    <Label Text="{Binding Draw.SlotDigit3}"
                                           StyleClass="slot-digit"
                                           HorizontalOptions="Center" VerticalOptions="Center"/>
                                </Frame>
                            </Grid>
                        </Frame>
                        <Label Text="{Binding Draw.DrawnStudentDisplay}"
                               StyleClass="drawn-display"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Button Text="LOSUJ UCZNIA"
                                Command="{Binding Draw.DrawStudentCommand}"
                                BackgroundColor="{StaticResource PrimaryDark}"
                                Padding="20" CornerRadius="15"
                                HorizontalOptions="Center"
                                IsEnabled="{Binding Draw.IsSpinning, Converter={StaticResource InverseBoolConverter}}"
                                StyleClass="draw-button"/>
                    </VerticalStackLayout>
                </Frame>

                <!-- student list -->
                <Frame Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                       BackgroundColor="{StaticResource Secondary}"
                       BorderColor="{StaticResource Gray200}"
                       CornerRadius="10" Padding="15"
                       IsVisible="{Binding Class.IsClassSelected}"
                       MinimumHeightRequest="300">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Lista uczniów"
                               StyleClass="section-header"/>
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding StudentList.Students}" Spacing="5">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Frame BackgroundColor="{StaticResource BeeLight}"
                                           BorderColor="{StaticResource Gray200}"
                                           CornerRadius="10" Padding="10"
                                           StyleClass="card-frame">
                                        <Frame.Triggers>
                                            <DataTrigger TargetType="Frame" Binding="{Binding IsHighlighted}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource Tertiary}" />
                                                <Setter Property="BorderColor" Value="{StaticResource PrimaryDark}" />
                                            </DataTrigger>
                                        </Frame.Triggers>
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                            <Frame Grid.Column="0"
                                                   BackgroundColor="{Binding StatusColor}"
                                                   WidthRequest="40" HeightRequest="40"
                                                   CornerRadius="20" Padding="0"
                                                   VerticalOptions="Center">
                                                <Label Text="{Binding Number}"
                                                       StyleClass="number-badge"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Frame>
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                <Label Text="{Binding Name}"
                                                       StyleClass="student-name"
                                                       IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StudentList.IsEditing, Converter={StaticResource InverseBoolConverter}}"/>
                                                <Entry Text="{Binding Name}"
                                                       TextColor="{StaticResource BeeDark}"
                                                       BackgroundColor="{StaticResource Secondary}"
                                                       IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StudentList.IsEditing}" />
                                                <Label Text="{Binding StatusText}" StyleClass="student-status"/>
                                            </VerticalStackLayout>
                                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center">
                                                <Label Text="Obecny" StyleClass="student-presence-label"/>
                                                <CheckBox IsChecked="{Binding IsPresent}" Color="{StaticResource Primary}"/>
                                            </VerticalStackLayout>
                                            <Button Grid.Column="3"
                                                    Text="X"
                                                    BackgroundColor="{StaticResource PrimaryDark}"
                                                    WidthRequest="40"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StudentList.RemoveStudentCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StudentList.IsEditing}"
                                                    StyleClass="danger-button"/>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>

            </Grid>
        </ScrollView>

        <!-- confetti layer drawn on top by code-behind -->
        <AbsoluteLayout x:Name="ConfettiLayer"
                        AbsoluteLayout.LayoutBounds="0,0,1,1"
                        AbsoluteLayout.LayoutFlags="All"
                        InputTransparent="True" />
    </AbsoluteLayout>
</ContentPage>

