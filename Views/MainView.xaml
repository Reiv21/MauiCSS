<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:LosowankoPytanko.ViewModels"
             x:Class="LosowankoPytanko.Views.MainView"
             Title="System losowania uczniów">
    <ContentPage.BindingContext>
        <viewmodels:MainViewModel />
    </ContentPage.BindingContext>
    <AbsoluteLayout>
        <ScrollView AbsoluteLayout.LayoutBounds="0,0,1,1"
                    AbsoluteLayout.LayoutFlags="All">
            <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                  ColumnDefinitions="*,2*"
                  Padding="10"
                  RowSpacing="10"
                  ColumnSpacing="10">
                <VerticalStackLayout Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Spacing="4">
                    <Label Text="System losowania"
                           Style="{StaticResource Headline}"
                           StyleClass="title-label" />
                    <Label Text="{Binding StatusMessage}"
                           TextColor="{StaticResource BeeDark}"
                           FontSize="13"
                           HorizontalOptions="Center"
                           StyleClass="status-label" />
                </VerticalStackLayout>
                <Frame Grid.Row="1" Grid.Column="0"
                       BackgroundColor="{StaticResource Secondary}"
                       BorderColor="{StaticResource Gray200}"
                       CornerRadius="10"
                       Padding="15">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Zarządzanie klasami"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BeeDark}"
                               StyleClass="section-header"/>
                        <HorizontalStackLayout Spacing="5">
                            <Entry
                                   Placeholder="Nazwa nowej klasy"
                                   Text="{Binding NewClassName}"
                                   WidthRequest="150" />
                            <Button Text="+"
                                    Command="{Binding CreateClassCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource BeeDark}"
                                    WidthRequest="40"
                                    StyleClass="primary-button"/>
                        </HorizontalStackLayout>
                        <Picker
                                Title="Wybierz klasę"
                                ItemsSource="{Binding ClassNames}"
                                SelectedItem="{Binding SelectedClassName}" />
                        <HorizontalStackLayout Spacing="6" Margin="0,6,0,0">
                            <Entry Placeholder="Nowa nazwa klasy"
                                   Text="{Binding NewSelectedClassName}"
                                   WidthRequest="180" />
                            <Button Text="Zmień nazwę"
                                    Command="{Binding RenameClassCommand}"
                                    IsVisible="{Binding IsClassSelected}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource BeeDark}" />
                        </HorizontalStackLayout>
                        <HorizontalStackLayout Spacing="8">
                            <Button Text="Importuj"
                                    Command="{Binding ImportClassCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource BeeDark}"
                                    StyleClass="primary-button" />
                            <Button Text="Eksportuj"
                                    Command="{Binding ExportClassCommand}"
                                    BackgroundColor="{StaticResource PrimaryDark}"
                                    TextColor="{StaticResource BeeLight}"
                                    IsVisible="{Binding IsClassSelected}"
                                    StyleClass="secondary-button" />
                        </HorizontalStackLayout>
                        <Label Text="Eksport zapisuje do wybranego miejsca"
                               Style="{StaticResource HelperText}"
                               StyleClass="status-label" />
                        <Button Text="Usuń klasę"
                                Command="{Binding DeleteClassCommand}"
                                BackgroundColor="{StaticResource PrimaryDark}"
                                TextColor="{StaticResource BeeLight}"
                                IsVisible="{Binding IsClassSelected}"
                                StyleClass="danger-button"/>
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="1" Grid.Column="1"
                       BackgroundColor="{StaticResource Secondary}"
                       BorderColor="{StaticResource Primary}"
                       CornerRadius="10"
                       Padding="15">
                    <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="15">
                        <VerticalStackLayout Grid.Column="0" VerticalOptions="Center">
                            <Label Text="Szczęśliwy numerek"
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BeeDark}"
                                   StyleClass="section-header"/>
                            <Label Text="{Binding LuckyNumber}"
                                   FontSize="48"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource PrimaryDarkText}"
                                   HorizontalOptions="Center"
                                   StyleClass="lucky-number-label"/>
                            <Label Text="Tutaj możesz wpisać szczęśliwy numerek (ręcznie) lub użyć przycisku."
                                   Style="{StaticResource HelperText}"
                                   StyleClass="status-label"/>
                        </VerticalStackLayout>
                        <Entry
                               Grid.Column="1"
                               Text="{Binding LuckyNumberString, Mode=TwoWay}"
                               Keyboard="Numeric"
                               WidthRequest="200"
                               VerticalOptions="Center"
                               Placeholder="Wpisz numer"
                               TextColor="{StaticResource BeeDark}"
                               BackgroundColor="{StaticResource Secondary}" />
                        <Button Grid.Column="2"
                                Text="Losuj numerek"
                                Command="{Binding GenerateLuckyNumberCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="{StaticResource BeeDark}"
                                VerticalOptions="Center"
                                StyleClass="primary-button"/>
                    </Grid>
                </Frame>
                <Frame Grid.Row="2" Grid.Column="0"
                       BackgroundColor="{StaticResource Secondary}"
                       BorderColor="{StaticResource Gray200}"
                       CornerRadius="10"
                       Padding="15"
                       IsVisible="{Binding IsClassSelected}">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Dodaj ucznia"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BeeDark}"
                               StyleClass="section-header"/>
                        <Entry
                               Placeholder="Imię i nazwisko"
                               Text="{Binding NewStudentName}" />
                        <Button Text="Dodaj ucznia"
                                Command="{Binding AddStudentCommand}"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="{StaticResource BeeLight}"
                                StyleClass="success-button"/>
                        <HorizontalStackLayout Spacing="10">
                            <Button Text="{Binding IsEditing, Converter={StaticResource BoolToEditTextConverter}}"
                                    Command="{Binding ToggleEditModeCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource BeeDark}"
                                    StyleClass="primary-button"/>
                            <Button Text="Resetuj"
                                    Command="{Binding ResetQuestionedCommand}"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="{StaticResource BeeDark}"
                                    StyleClass="primary-button"/>
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="2" Grid.Column="1"
                       BackgroundColor="{StaticResource Secondary}"
                       BorderColor="{StaticResource Gray200}"
                       CornerRadius="15"
                       Padding="20"
                       IsVisible="{Binding IsClassSelected}">
                    <VerticalStackLayout Spacing="12">
                        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
                            <Label Grid.Column="0"
                                   Text=""
                                   FontSize="18"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource BeeDark}"
                                   HorizontalOptions="Center"
                                   StyleClass="section-header"/>
                            <Frame Grid.Column="1"
                                   BackgroundColor="{StaticResource PrimaryDark}"
                                   CornerRadius="10"
                                   Padding="6,10"
                                   WidthRequest="14"
                                   HeightRequest="60"
                                   VerticalOptions="Center"/>
                        </Grid>
                        <Frame BackgroundColor="{StaticResource PrimaryDark}"
                               BorderColor="{StaticResource Gray200}"
                               CornerRadius="14"
                               Padding="12">
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8" HorizontalOptions="Center">
                                <Frame Grid.Column="0"
                                       BackgroundColor="{StaticResource BeeLight}"
                                       BorderColor="{StaticResource Gray200}"
                                       CornerRadius="10"
                                       Padding="8"
                                       WidthRequest="70"
                                       HeightRequest="90">
                                    <Label Text="{Binding SlotDigit1}"
                                           FontSize="36"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BeeDark}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <Frame Grid.Column="1"
                                       BackgroundColor="{StaticResource BeeLight}"
                                       BorderColor="{StaticResource Gray200}"
                                       CornerRadius="10"
                                       Padding="8"
                                       WidthRequest="70"
                                       HeightRequest="90">
                                    <Label Text="{Binding SlotDigit2}"
                                           FontSize="36"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BeeDark}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <Frame Grid.Column="2"
                                       BackgroundColor="{StaticResource BeeLight}"
                                       BorderColor="{StaticResource Gray200}"
                                       CornerRadius="10"
                                       Padding="8"
                                       WidthRequest="70"
                                       HeightRequest="90">
                                    <Label Text="{Binding SlotDigit3}"
                                           FontSize="36"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BeeDark}"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                            </Grid>
                        </Frame>
                        <!-- SmallConfettiLayer usunięto; konfetti rysowane jest w ConfettiLayer (code-behind) -->
                        <Label Text="{Binding DrawnStudentDisplay}"
                               FontSize="16"
                               TextColor="{StaticResource BeeDark}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center"/>
                        <Button Text="LOSUJ UCZNIA"
                                Command="{Binding DrawStudentCommand}"
                                BackgroundColor="{StaticResource PrimaryDark}"
                                TextColor="{StaticResource BeeLight}"
                                FontSize="20"
                                FontAttributes="Bold"
                                Padding="20"
                                CornerRadius="15"
                                HorizontalOptions="Center"
                                IsEnabled="{Binding IsSpinning, Converter={StaticResource InverseBoolConverter}}"
                                StyleClass="draw-button"/>
                    </VerticalStackLayout>
                </Frame>
                <Frame Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                       BackgroundColor="{StaticResource Secondary}"
                       BorderColor="{StaticResource Gray200}"
                       CornerRadius="10"
                       Padding="15"
                       IsVisible="{Binding IsClassSelected}"
                       MinimumHeightRequest="300">
                    <VerticalStackLayout Spacing="10">
                        <Label Text="Lista uczniów"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="{StaticResource BeeDark}"
                               StyleClass="section-header"/>
                        <VerticalStackLayout BindableLayout.ItemsSource="{Binding Students}" Spacing="5">
                            <BindableLayout.ItemTemplate>
                                <DataTemplate>
                                    <Frame BackgroundColor="{StaticResource BeeLight}"
                                           BorderColor="{StaticResource Gray200}"
                                           CornerRadius="10"
                                           Padding="10"
                                           StyleClass="card-frame">
                                        <Frame.Triggers>
                                            <DataTrigger TargetType="Frame" Binding="{Binding IsHighlighted}" Value="True">
                                                <Setter Property="BackgroundColor" Value="{StaticResource Tertiary}" />
                                                <Setter Property="BorderColor" Value="{StaticResource PrimaryDark}" />
                                            </DataTrigger>
                                        </Frame.Triggers>
                                        <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                            <Frame Grid.Column="0"
                                                   BackgroundColor="{Binding StatusColor}"
                                                   WidthRequest="40"
                                                   HeightRequest="40"
                                                   CornerRadius="20"
                                                   Padding="0"
                                                   VerticalOptions="Center">
                                                <Label Text="{Binding Number}"
                                                       TextColor="{StaticResource BeeLight}"
                                                       FontAttributes="Bold"
                                                       HorizontalOptions="Center"
                                                       VerticalOptions="Center"/>
                                            </Frame>
                                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                                <Label Text="{Binding Name}" FontSize="16" TextColor="{StaticResource BeeDark}"
                                                       IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsEditing, Converter={StaticResource InverseBoolConverter}}"/>
                                                <Entry Text="{Binding Name}" FontSize="16" TextColor="{StaticResource BeeDark}"
                                                       BackgroundColor="{StaticResource Secondary}"
                                                       IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsEditing}" />
                                                <Label Text="{Binding StatusText}" FontSize="12" TextColor="{StaticResource Gray500}"/>
                                            </VerticalStackLayout>
                                            <VerticalStackLayout Grid.Column="2" VerticalOptions="Center">
                                                <Label Text="Obecny" FontSize="10" TextColor="{StaticResource BeeDark}"/>
                                                <CheckBox IsChecked="{Binding IsPresent}" Color="{StaticResource Primary}"/>
                                            </VerticalStackLayout>
                                            <Button Grid.Column="3"
                                                    Text="X"
                                                    BackgroundColor="{StaticResource PrimaryDark}"
                                                    TextColor="{StaticResource BeeLight}"
                                                    WidthRequest="40"
                                                    Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.RemoveStudentCommand}"
                                                    CommandParameter="{Binding}"
                                                    IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.IsEditing}"
                                                    StyleClass="danger-button"/>
                                        </Grid>
                                    </Frame>
                                </DataTemplate>
                            </BindableLayout.ItemTemplate>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Frame>
            </Grid>
        </ScrollView>
        <AbsoluteLayout x:Name="ConfettiLayer"
                        AbsoluteLayout.LayoutBounds="0,0,1,1"
                        AbsoluteLayout.LayoutFlags="All"
                        InputTransparent="True" />
    </AbsoluteLayout>
</ContentPage>
