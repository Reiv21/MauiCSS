<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiCSS.Views.StudentListView">
    <Frame BackgroundColor="{StaticResource Secondary}"
           BorderColor="{StaticResource Gray200}"
           CornerRadius="10" Padding="15"
           IsVisible="{Binding Class.IsClassSelected}"
           MinimumHeightRequest="300">
        <VerticalStackLayout Spacing="10">
            <Label Text="Lista uczniów"
                   StyleClass="section-header"/>
            <VerticalStackLayout BindableLayout.ItemsSource="{Binding StudentList.Students}" Spacing="5">
                <BindableLayout.ItemTemplate>
                    <DataTemplate>
                        <Frame BackgroundColor="{StaticResource BeeLight}"
                               BorderColor="{StaticResource Gray200}"
                               CornerRadius="10" Padding="10"
                               StyleClass="card-frame">
                            <Frame.Triggers>
                                <DataTrigger TargetType="Frame" Binding="{Binding IsHighlighted}" Value="True">
                                    <Setter Property="BackgroundColor" Value="{StaticResource Tertiary}" />
                                    <Setter Property="BorderColor" Value="{StaticResource PrimaryDark}" />
                                </DataTrigger>
                            </Frame.Triggers>
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="10">
                                <Frame Grid.Column="0"
                                       BackgroundColor="{Binding StatusColor}"
                                       WidthRequest="40" HeightRequest="40"
                                       CornerRadius="20" Padding="0"
                                       VerticalOptions="Center">
                                    <Label Text="{Binding Number}"
                                           StyleClass="number-badge"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"/>
                                </Frame>
                                <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                    <Label Text="{Binding Name}"
                                           StyleClass="student-name"
                                           IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StudentList.IsEditing, Converter={StaticResource InverseBoolConverter}}"/>
                                    <Entry Text="{Binding Name}"
                                           TextColor="{StaticResource BeeDark}"
                                           BackgroundColor="{StaticResource Secondary}"
                                           IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StudentList.IsEditing}" />
                                    <Label Text="{Binding StatusText}" StyleClass="student-status"/>
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="2" VerticalOptions="Center">
                                    <Label Text="Obecny" StyleClass="student-presence-label"/>
                                    <CheckBox IsChecked="{Binding IsPresent}" Color="{StaticResource Primary}"/>
                                </VerticalStackLayout>
                                <Button Grid.Column="3"
                                        Text="X"
                                        BackgroundColor="{StaticResource PrimaryDark}"
                                        WidthRequest="40"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StudentList.RemoveStudentCommand}"
                                        CommandParameter="{Binding}"
                                        IsVisible="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.StudentList.IsEditing}"
                                        StyleClass="danger-button"/>
                            </Grid>
                        </Frame>
                    </DataTemplate>
                </BindableLayout.ItemTemplate>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </Frame>
</ContentView>
